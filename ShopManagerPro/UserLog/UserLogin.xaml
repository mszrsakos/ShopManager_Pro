<Window
    x:Class="ShopManagerPro.UserLog.UserLogin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ShopManagerPro.UserLog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="UserLogin"
    Width="300"
    Height="450"
    mc:Ignorable="d"
    Background="Black">

    <StackPanel Margin="20" Orientation="Vertical">
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            FontSize="16"
            FontWeight="Bold"
            Text="ShopManagerPro bejelentkezés" 
            Foreground="white"/>
        <Grid VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />


            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Margin="0,15"
                HorizontalAlignment="Left"
                Text="Felhasználónév: " 
                Foreground="White"/>
            <TextBox
                x:Name="loginUserText"
                Grid.Row="1"
                Width="255"
                Height="35"
                HorizontalAlignment="Left" />
            <TextBlock
                Grid.Row="2"
                Margin="0,15"
                HorizontalAlignment="Left"
                Text="Jelszó: " 
                Foreground="White"/>
            <PasswordBox
                x:Name="loginPasswordText"
                Grid.Row="3"
                Width="255"
                Height="35"
                HorizontalAlignment="Left" />
        </Grid>

        <Button
            x:Name="LoginBtn"
            Width="250"
            Height="35"
            Margin="0,20,0,0"
            Background="White"
            Click="LoginBtn_Click"
            Content="Belépés"
            FontSize="20"
            Foreground="Black" />
    </StackPanel>
</Window>
