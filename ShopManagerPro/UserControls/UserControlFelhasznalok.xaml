<UserControl x:Class="ShopManagerPro.UserControls.UserControlFelhasznalok"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <StackPanel Margin="10">

        <DataGrid x:Name="datagridFelhasznalok"
                  Width="1000"
                  Height="500"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionChanged="datagridFelhasznalok_SelectionChanged">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}" />

                <DataGridTextColumn Header="Felhasználónév"
                                    Binding="{Binding FhNev}" />

                <DataGridTextColumn Header="Teljes név"
                                    Binding="{Binding TeljesNev}" />

                <DataGridTextColumn Header="Jelszó"
                                    Binding="{Binding Jelszo}" />

                <DataGridTextColumn Header="Szerepkör"
                                    Binding="{Binding SzerepkorNev}" />

            </DataGrid.Columns>

        </DataGrid>

        <WrapPanel Margin="0,20,0,0">

            <StackPanel Width="300">

                <TextBlock Text="Felhasználónév:" />
                <TextBox x:Name="felhasznaloNevTxtBx"
                         Margin="0,5,0,10"/>

                <TextBlock Text="Teljes név:" />
                <TextBox x:Name="teljesNevTxtBx"
                         Margin="0,5,0,10"/>

                <TextBlock Text="Jelszó:" />
                <PasswordBox x:Name="jelszoBx"
                             Margin="0,5,0,10"/>

                <TextBlock Text="Szerepkör:" />
                <ComboBox x:Name="szerepkor"
                          Margin="0,5,0,10"/>

            </StackPanel>

            <StackPanel Margin="20,0,0,0">

                <Button x:Name="mentesBtn"
                        Width="200"
                        Height="40"
                        Margin="0,10"
                        Background="DarkGreen"
                        Foreground="White"
                        Content="Mentés"
                        Click="mentesBtn_Click"/>

                <Button x:Name="modBth"
                        Width="200"
                        Height="40"
                        Margin="0,10"
                        Background="Orange"
                        Foreground="Black"
                        Content="Módosítás"
                        Click="modBth_Click"/>

                <Button x:Name="torlesBtn"
                        Width="200"
                        Height="40"
                        Margin="0,10"
                        Background="DarkRed"
                        Foreground="White"
                        Content="Törlés"
                        Click="torlesBtn_Click"/>

            </StackPanel>

        </WrapPanel>

    </StackPanel>

</UserControl>